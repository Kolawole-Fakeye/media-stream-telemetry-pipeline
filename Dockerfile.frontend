# Use the same lightweight Python 3.11 image for stability
FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .

RUN pip install --no-cache-dir fastapi uvicorn pydantic pandas pyarrow requests plotly streamlit

COPY . .

# Expose the standard Streamlit communication port
EXPOSE 8501

# Command to launch the Streamlit app on container startup
CMD ["streamlit", "run", "ui.py", "--server.port=8501", "--server.address=0.0.0.0"]
